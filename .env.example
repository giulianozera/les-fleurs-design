# ─────────────────────────────────────────────────────────────────────────────
# Les Fleurs Design — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://lesfleursdesign.com

# ── Sanity CMS (Phase 2) ─────────────────────────────────────────────────────
# Create project at sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=        # Read-only token for server-side data fetching
SANITY_WEBHOOK_SECRET=        # Secret for validating Sanity webhooks (revalidation)

# ── Supabase (Phase 3) ────────────────────────────────────────────────────────
# Create project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=    # Server-side only — never expose to client

# ── Stripe (Phase 3) ──────────────────────────────────────────────────────────
# Get keys at dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=        # `stripe listen --forward-to` output during dev

# ── EasyPost / UPS Shipping (Phase 4) ────────────────────────────────────────
# Create account at easypost.com
EASYPOST_API_KEY=

# Shipping origin address (1420 NE Miami Pl, Miami, FL 33132)
SHIPPING_ORIGIN_NAME=Les Fleurs Design
SHIPPING_ORIGIN_STREET1=1420 NE Miami Pl
SHIPPING_ORIGIN_CITY=Miami
SHIPPING_ORIGIN_STATE=FL
SHIPPING_ORIGIN_ZIP=33132
SHIPPING_ORIGIN_COUNTRY=US
SHIPPING_ORIGIN_PHONE=          # Your business phone number

# ── Resend (Phase 5) ──────────────────────────────────────────────────────────
# Create account at resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@lesfleursdesign.com
RESEND_ADMIN_EMAIL=             # Your inbox for B2B inquiry notifications

# ── Cal.com (Phase 5) ─────────────────────────────────────────────────────────
# Create account at cal.com — embed the scheduling link
NEXT_PUBLIC_CALCOM_LINK=        # e.g. https://cal.com/lesfleursdesign/wholesale-call

# ── Auth secret (Phase 3 — used by NextAuth if needed) ────────────────────────
NEXTAUTH_SECRET=                # Generate with: openssl rand -base64 32
NEXTAUTH_URL=https://lesfleursdesign.com
